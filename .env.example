# Gmail SMTP settings for real OTP email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_full_gmail@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=your_full_gmail@gmail.com
SMTP_USE_TLS=true

# Keep dev data directory mapping unchanged in compose:
# PRACTICE_HOME=/data

# For real email OTP (not log-only dev mode):
OTP_DEV_MODE=false

# Local HTTP dev default:
COOKIE_SECURE=false
