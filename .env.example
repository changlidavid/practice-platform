# --- Core runtime ---
# Container data root (usually leave as /data).
PRACTICE_HOME=/data
# Optional multi-bundle startup import (comma-separated paths).
# Relative paths are resolved from repo root.
# When set, this takes precedence over PRACTICE_BUNDLE_PATH.
# Example:
# PRACTICE_BUNDLE_PATHS=9021,final
# Legacy single-bundle fallback:
# PRACTICE_BUNDLE_PATH=9021

# --- Auth behavior ---
# Development: true prints OTP to logs when SMTP is missing.
# Production-like: false to require real SMTP.
OTP_DEV_MODE=false

# true when served behind HTTPS; false for local HTTP development.
COOKIE_SECURE=false

# --- SMTP for OTP delivery ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_full_gmail@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=your_full_gmail@gmail.com
SMTP_USE_TLS=true

# --- Runner hardening (optional) ---
# PRACTICE_DOCTEST_TIMEOUT_SECONDS=5
# PRACTICE_DOCTEST_OUTPUT_MAX_BYTES=262144
